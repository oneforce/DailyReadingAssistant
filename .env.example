# Qiniu Cloud Storage Config (If applicable)
VITE_QINIU_AK=your_qiniu_ak_here
VITE_QINIU_SK=your_qiniu_sk_here
VITE_QINIU_BUCKET=your_qiniu_bucket_here

# PocketBase API Backend URL
# If empty, frontend defaults to relatively path `/` in production or `http://106.54.239.44:9001` locally.
VITE_PB_API_URL=

# PocketBase Admin Credentials (used exclusively for node init_pb.mjs to setup database tables automatically)
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=your_secure_password_here
