# ============================================================
# pocket-data-backup Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── PocketBase 备份源 (A) ──
# 每天从这个 PB 实例导出数据
PB_API_URL=http://106.54.239.44:9001
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=your_secure_password

# ── PocketBase 恢复目标 (B)（可选） ──
# 用于快速验证备份：从 Git 恢复数据到另一个 PB 实例
# 如果不填，恢复脚本默认使用上面的备份源地址
PB_RESTORE_API_URL=
PB_RESTORE_ADMIN_EMAIL=
PB_RESTORE_ADMIN_PASSWORD=

# ── Git Author Identity ──
GIT_USER_NAME=pocket-data-backup
GIT_USER_EMAIL=backup@dailyreading.app

# ── SSH Key Path (on host machine) ──
# This key must have push access to the Git repository
SSH_KEY_PATH=~/.ssh/id_rsa

# ── Behavior ──
# Set to "true" to run backup immediately when container starts
RUN_ON_START=true
